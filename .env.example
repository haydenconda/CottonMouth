# Slack (xoxp user token preferred for full private channel access)
SLACK_USER_TOKEN=xoxp-your-token
SLACK_TEAM_ID=your-team-id
SLACK_USER_ID=your-user-id
# Priority channels to always monitor (names or channel IDs like C0XXXXXXX)
SLACK_CHANNELS=your-channel-1,your-channel-2
# Firehose channels: stream ALL messages to the live feed / ticker (not just mentions)
SLACK_FIREHOSE_CHANNELS=your-channel-1,your-channel-2

# Jira / Atlassian
ATLASSIAN_SITE_URL=https://your-org.atlassian.net
ATLASSIAN_USER_EMAIL=you@company.com
ATLASSIAN_API_TOKEN=your-token

# GitHub
GITHUB_TOKEN=your-token
GITHUB_USERNAME=your-username
GITHUB_WATCHED_REPOS=org/repo-1,org/repo-2

# ArgoCD
ARGOCD_BASE_URL=https://argocd.example.com
ARGOCD_API_TOKEN=your-token

# Grafana
GRAFANA_URL=https://grafana.example.com
GRAFANA_SERVICE_ACCOUNT_TOKEN=your-token

# Cloudflare
CLOUDFLARE_API_TOKEN=your-token
CLOUDFLARE_ACCOUNT_ID=your-account-id

# AWS
AWS_PROFILE=your-profile
AWS_REGION=us-east-1

# AWS Bedrock (uses AWS_PROFILE SSO credentials — no API key needed)
BEDROCK_MODEL=us.anthropic.claude-opus-4-6-v1
BEDROCK_REGION=us-east-1
